{
    "name": "arcanum-org/framework",
    "description": "A robust CQRS framework for building powerful applications.",
    "type": "library",
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1",
        "php-coveralls/php-coveralls": "^2.9",
        "squizlabs/php_codesniffer": "^3.7",
        "phpmetrics/phpmetrics": "^2.9"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Arcanum\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Arcanum\\Test\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Stephen Young",
            "email": "young.steveo@gmail.com"
        },
        {
            "name": "Claude (Anthropic)",
            "homepage": "https://claude.ai"
        }
    ],
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.4",
        "psr/container": "^2.0",
        "psr/event-dispatcher": "^1.0",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "vlucas/phpdotenv": "^5.5",
        "symfony/finder": "^6.3 || ^7.0",
        "monolog/monolog": "^3.4",
        "voku/portable-ascii": "^2.0",
        "psr/simple-cache": "^3.0",
        "psr/clock": "^1.0"
    },
    "scripts": {
        "post-install-cmd": [
            "bash contrib/setup"
        ],
        "check": [
            "@cs-fix",
            "@cs-check",
            "@phpstan",
            "@phpunit"
        ],
        "cs-check": "bash contrib/cs-check",
        "cs-fix": "phpcbf --colors --standard=./contrib/phpcs-ruleset.xml --ignore=.coverage,.phpunit.cache",
        "phpstan": "bash contrib/phpstan",
        "phpunit": "phpunit --colors=always --log-junit=tests/.coverage/junit.xml --configuration=contrib/phpunit.xml --display-warnings",
        "metrics": "phpmetrics --report-html=.metrics --junit=tests/.coverage/junit.xml --git=/usr/bin/git ./src"
    }
}
